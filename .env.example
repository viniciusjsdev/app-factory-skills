# Executor selection: auto, opencode, or codex.
APP_FACTORY_BACKEND_EXECUTOR=auto

# OpenCode Go model used for heavy backend implementation.
APP_FACTORY_OPENCODE_MODEL=opencode-go/kimi-k2.7-code

# Maximum passive wait for one OpenCode execution.
APP_FACTORY_OPENCODE_TIMEOUT_MINUTES=120

# Optional command override, useful when OpenCode is installed in a custom path.
# APP_FACTORY_OPENCODE_COMMAND=opencode

# Optional absolute path to the App Factory non-secret environment file when
# invoking an installed router skill from outside this repository.
# APP_FACTORY_ENV_FILE=D:\Projetos\Skills\app-factory-skills\.env

# Never place the OpenCode Go API key here. Authenticate with `opencode auth login`
# or `/connect`; OpenCode stores credentials outside this repository.

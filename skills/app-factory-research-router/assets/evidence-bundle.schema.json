{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://app-factory.local/schemas/evidence-bundle.schema.json",
  "title": "App Factory Market Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "research_id", "generated_at", "items", "search_failures"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "research_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_id", "claim", "evidence_class", "source", "retrieval", "field_status", "confidence"],
        "properties": {
          "evidence_id": { "type": "string", "minLength": 1 },
          "claim": { "type": "string", "minLength": 1 },
          "evidence_class": { "type": "string", "minLength": 1 },
          "source": {
            "type": "object",
            "required": ["name", "url_or_id", "retrieved_at"],
            "properties": {
              "name": { "type": "string" },
              "url_or_id": { "type": "string" },
              "publisher": { "type": "string" },
              "published_or_observed_at": { "type": "string" },
              "retrieved_at": { "type": "string", "format": "date-time" }
            }
          },
          "retrieval": {
            "type": "object",
            "required": ["mechanism"],
            "properties": {
              "mechanism": { "enum": ["codex", "appstoretracker", "apple", "openalex", "perplexity", "manus", "manual", "experiment"] },
              "query_or_task_id": { "type": "string" }
            }
          },
          "scope": { "type": "object" },
          "field_status": { "enum": ["observed", "modeled_estimate", "derived", "unknown"] },
          "transformation": { "type": "string" },
          "dependence_group": { "type": "string" },
          "confidence": { "enum": ["low", "medium", "high"] },
          "limitations": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "search_failures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "reason"],
        "properties": {
          "task_id": { "type": "string" },
          "provider": { "type": "string" },
          "reason": { "type": "string" },
          "impact": { "type": "string" }
        }
      }
    }
  }
}

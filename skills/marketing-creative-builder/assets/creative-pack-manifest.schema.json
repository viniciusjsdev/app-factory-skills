{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://app-factory.local/schemas/creative-pack-manifest.schema.json",
  "title": "Marketing Creative Pack Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "launch_id", "pack_id", "status", "channel", "artifacts", "claims", "external_state_changed"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "launch_id": { "type": "string", "minLength": 1 },
    "pack_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "review_required", "approved_for_routing"] },
    "channel": { "type": "string", "minLength": 1 },
    "campaign_id": { "type": "string" },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["artifact_id", "format", "variant_id", "files", "copy", "cta", "approval_status"],
        "properties": {
          "artifact_id": { "type": "string" },
          "format": { "type": "string" },
          "variant_id": { "type": "string" },
          "hypothesis": { "type": "string" },
          "files": { "type": "array", "items": { "type": "string" } },
          "copy": { "type": "object" },
          "accessibility": { "type": "object" },
          "cta": { "type": "string" },
          "destination": { "type": "string" },
          "utm": { "type": "object" },
          "approval_status": { "enum": ["draft", "review_required", "approved"] }
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "status"],
        "properties": {
          "claim": { "type": "string" },
          "status": { "enum": ["proven", "hypothesis", "prohibited"] },
          "evidence": { "type": "string" }
        }
      }
    },
    "external_state_changed": { "const": false }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://app-factory.local/schemas/platform-research-result.schema.json",
  "title": "Read-only Platform Research Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_id", "status", "platform", "observed_at", "results", "limitations", "external_state_changed"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "task_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["completed", "partial", "authentication_required", "scope_clarification_required", "blocked"] },
    "platform": { "type": "string", "minLength": 1 },
    "query": { "type": "object" },
    "observed_at": { "type": "string", "format": "date-time" },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stable_id_or_handle", "url", "relevance_evidence", "confidence"],
        "properties": {
          "stable_id_or_handle": { "type": "string" },
          "url": { "type": "string" },
          "display_name": { "type": "string" },
          "relevance_evidence": { "type": "array", "items": { "type": "string" } },
          "observed_metrics": { "type": "object" },
          "matching_content": { "type": "array", "items": { "type": "string" } },
          "inferences": { "type": "array", "items": { "type": "string" } },
          "risks": { "type": "array", "items": { "type": "string" } },
          "confidence": { "enum": ["low", "medium", "high"] }
        }
      }
    },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "search_failures": { "type": "array", "items": { "type": "string" } },
    "external_state_changed": { "const": false }
  }
}

{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/kimi-k2.7-code",
  "small_model": "opencode-go/deepseek-v4-flash",
  "enabled_providers": ["opencode-go"],
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "skill": "allow",
    "edit": {
      "*": "allow",
      "**/.git/**": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/AGENTS.md": "deny",
      "**/.codex/**": "deny",
      "**/docs/architecture/*.md": "deny",
      "**/migrations/*.py": "deny"
    },
    "bash": {
      "*": "allow",
      "git *": "deny",
      "git status*": "allow",
      "git diff*": "allow",
      "git ls-files*": "allow",
      "git rev-parse*": "allow",
      "git reset*": "deny",
      "git clean*": "deny",
      "git checkout*": "deny",
      "git switch*": "deny",
      "git commit*": "deny",
      "git push*": "deny",
      "rm -rf *": "deny",
      "Remove-Item * -Recurse*": "deny"
    },
    "external_directory": "deny",
    "task": "deny",
    "question": "deny",
    "webfetch": "deny",
    "websearch": "deny"
  }
}

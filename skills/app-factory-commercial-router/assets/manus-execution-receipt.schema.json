{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://app-factory.local/schemas/manus-execution-receipt.schema.json",
  "title": "Manus Commercial Execution Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "operation_id", "mode", "status", "platform", "account_id", "started_at", "completed_at", "changed_objects", "evidence", "errors", "retries", "external_state_changed"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "operation_id": { "type": "string", "minLength": 1 },
    "provider_task_id": { "type": "string" },
    "mode": { "enum": ["publish", "schedule", "approved_contact", "metrics_read", "crm_update"] },
    "status": { "enum": ["succeeded", "partial", "failed", "unknown", "precondition_failed"] },
    "platform": { "type": "string", "minLength": 1 },
    "account_id": { "type": "string", "minLength": 1 },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "changed_objects": { "type": "array", "items": { "type": "object" } },
    "evidence": { "type": "array", "items": { "type": "object" } },
    "errors": { "type": "array", "items": { "type": "object" } },
    "retries": { "type": "integer", "minimum": 0 },
    "reported_usage": { "type": "object" },
    "external_state_changed": { "type": "boolean" }
  }
}
